;
; Thickness = 0.30 m
; T = linear interpolation between soil (278.25K) and snow bottom (267.15K):
;     fraction = 1.0/(1.0+0.3) = 0.769 from bottom
;     T = 278.25 + 0.769*(267.15-278.25) = 269.71 K (-3.44°C)
;
; Rho_S       = 2300 kg/m³
; Conduc_S    = 1.70 W/(mK)  → R_concrete = 0.30/1.70 = 0.176 m²K/W
; HeatCapac_S =  880 J/(kgK) ← SPECIFIC (standard concrete)
; Vol_Frac_S  = 2300/2650 = 0.868
; Vol_Frac_W  = 0.02
; Vol_Frac_I  = 0.00
; Vol_Frac_V  = 1 - 0.868 - 0.02 = 0.112
; mk=9  (soil marker — Conduc_S locked, no metamorphism)
; =======================================================================
2024-04-01T00:00  0.30  269.71  0.00  0.02  0.112  0.868  2300.0  1.70  880.0  0.0  0.0  0.0  0.0  9  0.0  1  0.0  0.0



