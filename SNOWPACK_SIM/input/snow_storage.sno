;   LWC[2] = 0.0            →  Vol_Frac_W = 0.0
;   Vol_Frac_V = 1 - 0.436 - 0.0 = 0.564
;   Layer thickness = Hs/Ns = 4.5/3 = 1.5 m
;   rho_s = 400 kg/m³  →  rg=0.40 mm, rb=0.20 mm (aged rounded grains)
