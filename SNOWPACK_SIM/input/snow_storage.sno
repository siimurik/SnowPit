; =======================================================================
; LAYER 6 — INSULATION cover (wood chips, top-most layer)
;
; Python _INS_PAR / module-level constants:
;   Hi       = 0.20 m              →  Layer_Thick = 0.20
;   T_init   = midpoint(T_air=284K, T_snow_top=271K) = 277.6 K
;   rho_dry  = 100 kg/m³
;   W_init   = 5.0 kg/m²  →  Vol_Frac_W = W/(Hi*rho_w) = 5.0/(0.20*1000) = 0.025
;   Vol_Frac_I = rho_dry/rho_ice_equiv ≈ 0.0  (wood chips, not ice)
;              = use 0.067 as structural solid fraction (rho_dry/rho_wood=100/1500)
;   Vol_Frac_V = 1 - 0.067 - 0.025 = 0.908
;   Vol_Frac_S = 0.0  (must be 0 in snow-domain layers with mk≠9)
;
;   Conduc_S   = k_eff at W_init=5, f=W/W_sat=5/30=0.167:
;                k_moist = k_dry + (k_sat-k_dry)*f^n_k
;                        = 0.05 + (0.12-0.05)*0.167^1.5 = 0.05 + 0.07*0.068 = 0.055
;                age_fac = 1.0 (age=0 days)  →  k_eff ≈ 0.055 W/(mK)
;                (will evolve; use starting value 0.055)
;
;   HeatCapac_S = c_dry = 990 J/(kgK)
;                 *** SPECIFIC heat [J/(kgK)], NOT volumetric ***
;                 SNOWPACK computes: C_vol = Rho_S * HeatCapac_S = 100*990 = 99,000 J/(m³K) ✓
;
;   rg=0.5, rb=0.2  (nonzero required — avoids FPE in conductivity routines)
;   mk=6  (technical/processed material — preserves user-specified Conduc_S,
;           no standard snow metamorphism applied)
; =======================================================================
;2024-04-01T00:00  0.20  277.60  0.067  0.025  0.908  0.0       0.0  0.055  1285000.0  0.5  0.2  0.0  1.0  13  0.0  1  0.0  0.0
;2024-04-01T00:00  0.20   278.15  0.0    0.0    0.846  0.154  1300.0  0.06   1285000    0.4  0.2  0.0  1.0  13  0.0  1  0.0  0.0

; =======================================================================
; INITIAL SNOW PROFILE FIELDS DESCRIPTION
; =======================================
; 
; Field         Description
; ------------- --------------------------------------------------
; YYYY          Year
; MM            Month
; DD            Day
; HH            Hour
; MI            Minutes
; Layer_Thick   layer thickness [m]
; T             layer temperature [K]
; Vol_Frac_I    fractional ice volume [0-1]
; Vol_Frac_W    fractional water volume [0-1]
; Vol_Frac_WP   fractional preferential flow water volume [0-1]
; Vol_Frac_V    fractional voids volume [0-1]
; Vol_Frac_S    fractional soil volume [0-1]
; 
; Rho_S         soil density [kg/m3]
; Conduc_S      mineral phase soil thermal conductivity [w/(mK)]
; HeatCapac_S   mineral phase soil thermal capacity [J/(kg*K)]
; rg            grain radius [mm]
; rb            bond radius [mm]
; dd            dendricity [0-1]
; sp            spericity [0-1]
; mk            marker, see Metamorphism.cc
; mass_hoar     mass of surface hoar []
; ne            number of elements
; CDot          stress change rate (initialize with 0.)
; metamo        currently unused
; =======================================================================

